{
  "name": "expo-app",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "scripts": {
    "postinstall": "patch-package",
    "expo:dev": "EXPO_PACKAGER_PROXY_URL=https://$REPLIT_DEV_DOMAIN REACT_NATIVE_PACKAGER_HOSTNAME=$REPLIT_DEV_DOMAIN EXPO_PUBLIC_DOMAIN=$REPLIT_DEV_DOMAIN:5000 expo start --localhost --port 8080",
    "server:dev": "LD_LIBRARY_PATH=/home/runner/workspace/node_modules/@tensorflow/tfjs-node/deps/lib:$LD_LIBRARY_PATH NODE_ENV=development tsx server/index.ts",
    "expo:start:static:build": "expo start --no-dev --minify --localhost",
    "expo:static:build": "node scripts/build.js",
    "server:build": "esbuild server/index.ts --platform=node --packages=external --bundle --format=esm --outdir=server_dist",
    "server:prod": "NODE_ENV=production node server_dist/index.js",
    "db:push": "drizzle-kit push",
    "start": "expo start",
    "lint": "expo lint",
    "lint:fix": "expo lint --fix"
  },
  "dependencies": {
    "@expo-google-fonts/inter": "^0.4.2",
